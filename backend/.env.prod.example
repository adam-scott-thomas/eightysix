# Copy to .env.prod and fill in values
# NEVER commit .env.prod to git

# Database
POSTGRES_PASSWORD=your_secure_password_here
DATABASE_URL=postgresql+asyncpg://chops:your_secure_password_here@db:5432/eightysix

# Auth
JWT_SECRET=generate-with-openssl-rand-hex-32

# CORS
CORS_ORIGINS=["https://quantumatiq.com"]

# Feature flags
DEMO_MODE=true
